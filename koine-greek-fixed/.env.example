# ═══════════════════════════════════════════════
# СКОПИРУЙТЕ ЭТОТ ФАЙЛ В .env.local
# и заполните все значения
# ═══════════════════════════════════════════════

# ── Supabase ──────────────────────────────────
# Найдёте в: Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXX...
SUPABASE_SERVICE_ROLE_KEY=eyXXXXXXX...

# ── ЮКасса ────────────────────────────────────
# Найдёте в: yookassa.ru → Настройки → Ключи API
YOOKASSA_SHOP_ID=123456
YOOKASSA_SECRET_KEY=live_XXXXXXXX...

# ── Сайт ──────────────────────────────────────
# Для локальной разработки: http://localhost:3000
# Для продакшена: https://ваш-домен.ru
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Цена курса (в рублях, целое число) ────────
NEXT_PUBLIC_COURSE_PRICE_RUB=14900

# ── Администратор ──────────────────────────────
# Ваш email — только этот адрес получит доступ к /admin
ADMIN_EMAIL=your@email.com
